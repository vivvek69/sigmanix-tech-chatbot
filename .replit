run = "python chatbot_production.py"
modules = ["python-3.11"]

[env]
PYTHONUNBUFFERABLE = "1"
FLASK_APP = "chatbot_production.py"
FLASK_ENV = "production"
PORT = "5000"

[packager]
language = "python3"
ignoredPaths = ["__pycache__", ".git", "venv", "archive"]

[packager.features]
enableGuessImports = true
